<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefWidth="850" prefHeight="600"
           style="-fx-background-color: linear-gradient(to bottom right, #3B727A, #1E3B40);"
           xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="org.example.cuoikijava.controller.RegisterController">

    <VBox maxWidth="400" maxHeight="450" alignment="CENTER" spacing="20"
          style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 15, 0, 0, 0);">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <Label text="ĐĂNG KÝ TÀI KHOẢN" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>

        <Separator prefWidth="200" />

        <VBox spacing="10">
            <TextField fx:id="txtFullName" promptText="Họ và tên" prefHeight="40"
                       style="-fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-color: transparent; -fx-font-size: 14px;"/>

            <TextField fx:id="txtPhone" promptText="Số điện thoại" prefHeight="40"
                       style="-fx-border-color: #cbd5e1; -fx-border-radius: 5; -fx-background-color: transparent; -fx-font-size: 14px;"/>

            <TextField fx:id="txtUsername" promptText="Tên đăng nhập" prefHeight="40"
                       style="-fx-border-color: #38bdf8; -fx-border-radius: 5; -fx-background-color: transparent; -fx-font-size: 14px;"/>

            <PasswordField fx:id="txtPassword" promptText="Mật khẩu" prefHeight="40"
                           style="-fx-border-color: #e2e8f0; -fx-border-radius: 5; -fx-background-color: transparent; -fx-font-size: 14px;"/>
        </VBox>

        <Button text="ĐĂNG KÝ" onAction="#handleRegister" prefWidth="320" prefHeight="45"
                style="-fx-background-color: #dc2626; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-size: 14px;"/>

        <HBox alignment="CENTER" spacing="5">
            <Label text="Đã có tài khoản?" textFill="#666666" style="-fx-font-size: 13px;"/>
            <Button text="Đăng nhập ngay" onAction="#openLogin"
                    style="-fx-background-color: transparent; -fx-text-fill: #38bdf8; -fx-cursor: hand; -fx-padding: 0; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>
</StackPane>